<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:gravity="right"
    android:background="?android:colorBackground">

    <!-- 🔵 TOOLBAR (برای منو بالا) -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:gravity="right"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#2196F3"
        android:title=" 🧠 تحلیل هوشمند متن "
        android:titleTextColor="#FFFFFF"
        android:paddingEnd="10dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- INPUT -->
            <EditText
                android:id="@+id/edtInput"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:hint=" متن را وارد کنید... "
                android:gravity="right"
                android:padding="12dp"
                android:textColor="@color/black"
                android:textColorHint="@color/black"
                android:background="@android:drawable/edit_text"
                android:textSize="16sp"/>

            <!-- ANALYZE BUTTON -->
            <Button
                android:id="@+id/btnAnalyze"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=" تحلیل متن "
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

            <!-- PIE CHART -->
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="14dp"/>


            <!-- EMOTION -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <TextView
                    android:gravity="right"
                    android:id="@+id/txtEmotion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="احساس غالب : --- "
                    android:textSize="18sp"
                    android:textColor="?android:textColorPrimary"
                    android:textColorHint="?android:textColorHint"
                    android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>

            <!-- TOPIC -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <TextView
                    android:gravity="right"
                    android:id="@+id/txtTopic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text=" موضوعات : --- "
                    android:textSize="18sp"
                    android:textColor="?android:textColorPrimary"
                    android:textColorHint="?android:textColorHint"
                    android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>

            <!-- KEYWORDS -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <TextView
                    android:gravity="right"
                    android:id="@+id/txtKeywords"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text=" کلمات کلیدی متن : ---"
                    android:textSize="18sp"
                    android:textColor="?android:textColorPrimary"
                    android:textColorHint="?android:textColorHint"
                    android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>

            <!-- SUMMARY -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <TextView
                    android:gravity="right"
                    android:id="@+id/txtSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text=" خلاصه متن : --- "
                    android:textSize="18sp"
                    android:textColor="?android:textColorPrimary"
                    android:textColorHint="?android:textColorHint"
                    android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>

            <!-- LOADING -->
            <ProgressBar
                android:gravity="right"
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/builder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/hyperlink"
                android:textSize="12sp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>